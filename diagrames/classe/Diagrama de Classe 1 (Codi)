@startuml

left to right direction
skinparam classAttributeIconSize 0

class "UsuariNoRegistrat" as NoReg #LightYellow {
  + consultarMenus()
  + consultarPlats()
  + registrarCompte()
  + iniciarSessio()
}

abstract class Usuari #LightYellow {
  - id : UUID
  - nom : String
  - cognom1 : String
  - cognom2 : String
  - email : String
  - adreca : String
  - nickUsuari : String
  - contrasenyaHash : String
  + iniciarSessio()
  + tancarSessio()
  + seleccionarTipusUsuari()
}

class Client #LightYellow {
  + ferComanda()
  + reservarComanda()
  + repetirComanda()
  + valorarComanda()
  + proposarPlatPersonalitzat()
  + veureHistorial()
  + esPremium()
  + tipusRecollida()
}

class Cuiner #LightYellow {
  - disponible : Boolean
  + publicarMenu()
  + actualitzarDisponibilitat()
  + acceptarProposta()
  + configurarOpcionsRecollida()
}

class Repartidor #LightYellow {
  + acceptarEnviament()
}

class Menu #LightBlue {
  - id : UUID
  - nom : String
}

class Plat #LightBlue{
  - id : UUID
  - nom : String
  - preuBase : Decimal
  - disponible : Boolean
  + modificarPlat()
}

class Comanda {
  - id : UUID
  - dataCreacio : DateTime
  - estat : EstatComanda
  - importTotal : Decimal
  + calcularImportTotal()
  + confirmarPagament()
}

class Enviament #LightBlue{
  - id : UUID
  - tipusRecollida : TipusRecollida
  - distanciaKm : Decimal
  - cost : Decimal
  + calcularCost()
}

abstract class MetodePagament #LightBlue{
  - id : UUID
  - alias : String
  + seleccionarMetode()
}

class TargetaBancaria #LightBlue
class CompteBancari #LightBlue
class PayPal #LightBlue

class Pagament #LightBlue {
  - id : UUID
  - import : Decimal
  - dataPagament : DateTime
  - estat : EstatPagament
  + pagar()
}

class Valoracio #LightBlue {
  - id : UUID
  - puntuacio : int
  - comentari : String
  - puntualitat : int
  - estatMenjar : int
  + valorarComentari()
  + valorarCuiner()
}

class Subscripcio #LightBlue{
  - id : UUID
  - activa : Boolean
  - quotaMensual : Decimal
  - dataAlta : Date
  + calcularDescompte()
}

class PropostaPlat #LightBlue{
  - id : UUID
  - descripcio : String
  - estat : EstatProposta
  + proposar()
}

class XatPrivat #LightBlue{
  - id : UUID
  - dataCreacio : DateTime
}

enum EstatComanda #LightBlue{
  CREADA
  ACCEPTADA
  EN_PREPARACIO
  EN_ENVIAMENT
  COMPLETADA
  CANCELLADA
}

enum TipusRecollida {
  REPARTIDOR
  CUINER
  CLIENT
}

enum EstatPagament {
  PENDENT
  CONFIRMAT
  REBUTJAT
}

/'
  Class11 <|.. Class12 flecha blanca
  Class13 --> Class14 flecha negra
  Class15 ..> Class16 flecha linea discontinua negra
  Class17 ..|> Class18 flecha linea discontinua blanca
  Class19 --* Class20 rombo negro
  Class05 o-- Class06 rombo blanc
'/

Usuari <|-* Client
Usuari <|-* Cuiner
Usuari <|-* Repartidor
NoReg "1"-->"*" Usuari
Usuari --- Menu : 1..1
Menu *-- Plat : 1..*
Client "*"---"*" Valoracio
Valoracio "1"--*"1" Comanda 
Comanda "1"*--"1" Enviament
Repartidor --> Enviament
Subscripcio "1"--*"1" Client
PropostaPlat --* Client
PropostaPlat --* Cuiner
PropostaPlat "*"*--"*" XatPrivat
Comanda *-- EstatComanda
Client *-- TipusRecollida
Pagament *-- EstatPagament
Usuari --> Comanda
' Metodes de Pagament'
Comanda "1" *-> "1" Pagament
Pagament "*" --> "1" MetodePagament
MetodePagament <|-- TargetaBancaria
MetodePagament <|-- CompteBancari
MetodePagament <|-- PayPal

@enduml
